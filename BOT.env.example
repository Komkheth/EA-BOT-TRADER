# MT5 Connection
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=MetaQuotes-Demo

# Server Configuration
PORT=3000
NODE_ENV=production

# Scalper Settings
SCALPER_LOT_SIZE=0.01
SCALPER_MAX_RISK=1.0
SCALPER_TAKE_PROFIT=50
SCALPER_STOP_LOSS=30
SCALPER_MAX_DAILY_TRADES=20
SCALPER_PROFIT_TARGET=5

# BTC Settings
BTC_LOT_SIZE=0.01
BTC_MAX_RISK=1.5
BTC_TAKE_PROFIT=100
BTC_STOP_LOSS=80
BTC_MAX_DAILY_TRADES=5

# Security
JWT_SECRET=your_super_secret_key_here
API_KEY=your_api_key_here

# Logging
LOG_LEVEL=info
